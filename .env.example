# Server identity
SERVER_NAME=server1

# API authentication secret (generate: openssl rand -hex 32)
API_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Shared secret between peers for cross-server API auth
# Both servers must have the same PEER_API_SECRET value
PEER_API_SECRET=CHANGE_ME_same_on_all_peer_servers

# Comma-separated list of peer API base URLs (Cloudflare Tunnel hostnames)
# Example: https://keyapi.server2.example.com,https://keyapi.server3.example.com
PEER_API_URLS=

# Comma-separated SSH hosts to test connectivity (user@cf-tunnel-hostname)
# Used by check-connectivity.sh and shown in /status endpoint
# Example: root@ukssh.rgodim.org,ubuntu@ukssh2.rgodim.org
PEER_SSH_HOSTS=root@ukssh.rgodim.org

# Cloudflare Tunnel token — OPTIONAL if running cloudflared on the host directly.
# cloudflared is expected to already be installed on every device.
# Set only if you want the container to manage the tunnel itself.
CF_TUNNEL_TOKEN=

# SSH user configuration
SSH_USER=sshuser
SSH_USER_SHELL=/bin/bash

# Ports — bound to 127.0.0.1 ONLY (loopback); cloudflared on the host forwards to these
SSH_LOCAL_PORT=2222    # host-side port mapped to container sshd (port 22 inside)
API_PORT=8080          # host-side port mapped to the key API

# Logging
LOG_LEVEL=INFO

# Optional: Webhook URL for key-change notifications (Slack/Teams/custom)
WEBHOOK_URL=
