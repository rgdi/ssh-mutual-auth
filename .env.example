# Node Environment Configuration
# Define identity and allowed tasks for this worker node

# The unique identity of this node
NODE_ID=node-eu-1

# The celery queue this node should subscribe to
NODE_QUEUE=queue_cpu

# Examples:
#
# GPU Server:
# NODE_ID=gpu-server
# NODE_QUEUE=queue_gpu
#
# CPU Server:
# NODE_ID=cpu-server
# NODE_QUEUE=queue_cpu
#
# Public Endpoint:
# NODE_ID=public-endpoint
# NODE_QUEUE=queue_public
