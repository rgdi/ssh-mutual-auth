# Server identity
SERVER_NAME=server1

# API authentication secret (generate: openssl rand -hex 32)
API_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# Shared secret between peers for cross-server API auth
# Both servers must have the same PEER_API_SECRET value
PEER_API_SECRET=CHANGE_ME_same_on_all_peer_servers

# Comma-separated list of peer API base URLs (Cloudflare Tunnel hostnames)
# Example: https://keyapi.server2.example.com,https://keyapi.server3.example.com
PEER_API_URLS=

# Cloudflare Tunnel token (from: cloudflared tunnel create <name>)
CF_TUNNEL_TOKEN=CHANGE_ME_cloudflare_tunnel_token

# SSH user configuration
SSH_USER=sshuser
SSH_USER_SHELL=/bin/bash

# API port (default: 8080 — change to any free port)
API_PORT=8080

# Logging
LOG_LEVEL=INFO

# Optional: Webhook URL for key-change notifications (Slack/Teams/custom)
WEBHOOK_URL=
